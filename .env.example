# Copy to `.env` and fill in. The .env file is gitignored.
# Anything left blank is fine — services that need it will warn at startup.

# ─── LangChain Chatbot (agent/chatbot.py) ───────────────────────────────────
# Pick which LLM the ReAct agent talks to.
# Options: openai (default) | gemini | claude | ollama (local, no key needed)
LLM_PROVIDER=openai

# ─── LLM Provider Keys ──────────────────────────────────────────────────────
# Set the one(s) matching your LLM_PROVIDER above.

# OpenAI — used by default (gpt-4o-mini)
OPENAI_API_KEY=

# Anthropic — only if LLM_PROVIDER=claude
ANTHROPIC_API_KEY=

# Google — LangChain's ChatGoogleGenerativeAI reads GOOGLE_API_KEY.
# Easiest setup: use the same Gemini key for both the chatbot and embeddings
# (the Gemini API key works for both products).
GOOGLE_API_KEY=

# ─── Gemini Embeddings (src/tools/embeddings.py) ────────────────────────────
# REQUIRED to (re)build the SKU description embeddings used by HDBSCAN clustering.
# Cached to data/processed/sku_desc_emb.parquet — only the first run pays for it.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── AWS / SageMaker (optional, only for DeepAR remote training) ────────────
# Local DeepAR via gluonts works WITHOUT any of these.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# IAM role ARN that SageMaker assumes for training jobs.
# Format: arn:aws:iam::<account-id>:role/<role-name>
AWS_SAGEMAKER_ROLE=
# S3 bucket where the training panel + model artifacts live.
AWS_S3_BUCKET=

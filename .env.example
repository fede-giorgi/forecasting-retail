# Copy to `.env` and fill in. The .env file is gitignored.
# Anything left blank is fine — services that need it will warn at startup.

# ─── Gemini Embedding 2 (mandatory for §4 of the playground) ────────────────
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── n8n (only needed if you boot the local Docker Compose stack) ───────────
# Basic-auth credentials shown when you open http://localhost:5678
N8N_USER=admin
N8N_PASSWORD=changeme
# LLM key the n8n AI-Agent node uses to reason (pick one — OpenAI is the path
# of least resistance; n8n also has native Gemini support if you prefer)
OPENAI_API_KEY=

# ─── AWS (only needed if you run DeepAR on SageMaker via the $100 credit) ───
# Local DeepAR via gluonts works WITHOUT any of these.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# IAM role ARN that SageMaker assumes for training jobs. Create once in AWS
# Console → IAM → Roles → "AmazonSageMakerFullAccess" + S3 access.
# Format: arn:aws:iam::<account-id>:role/<role-name>
AWS_SAGEMAKER_ROLE=
# S3 bucket where the training panel + model artifacts live.
# Create with: aws s3 mb s3://forecasting-retail-<your-suffix>
AWS_S3_BUCKET=
